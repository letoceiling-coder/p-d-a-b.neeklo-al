generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Document {
  id            String   @id @default(cuid())
  userId        String
  filePath      String
  text          String
  extractedJson Json?
  status        String   @default("UPLOADED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
